<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Homegym" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/hg_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/hg_secondary_1</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/hg_background_dark</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/hg_background_light</item>

        <!-- Estilo para el foco visual -->
        <item name="android:listChoiceBackgroundIndicator">@drawable/focus_border</item>
        <item name="android:selectableItemBackground">@drawable/focus_border</item>

        <!-- Evitar focos automáticos indeseados -->
        <item name="android:focusableInTouchMode">false</item>
    </style>
</resources>